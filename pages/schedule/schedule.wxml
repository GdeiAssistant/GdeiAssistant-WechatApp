<wxs module="scheduleHelper">
  function formatWeekButton(week, tpl) {
    if (!tpl || !week) return '';
    return tpl.replace('{{week}}', week);
  }
  function formatWeekRange(min, max, tpl) {
    if (!tpl) return '';
    return tpl.replace('{{min}}', min).replace('{{max}}', max);
  }
  module.exports = {
    formatWeekButton: formatWeekButton,
    formatWeekRange: formatWeekRange
  };
</wxs>

<view class="page__bd schedule-page {{themeClass}}" style="{{fontStyle}}">

  <view class="weui-navbar schedule-navbar">
    <block wx:for="{{tabs}}" wx:key="*this">
      <view id="{{index}}" class="weui-navbar__item {{activeIndex == index ? 'weui-bar__item_on' : ''}}" bindtap="tabClick">
        <view class="weui-navbar__title">{{item}}</view>
      </view>
    </block>
  </view>

  <view wx:if="{{week}}">
    <view class="schedule-toolbar">
      <picker bindchange="bindPickerChange" value="{{index}}" range="{{array}}">
        <button class="schedule-week-button" type="default" plain="true">
          {{scheduleHelper.formatWeekButton(week, t.weekLabel)}}
        </button>
      </picker>
    </view>
  </view>

  <view class="schedule-panel" wx:if="{{scheduleList}}">

    <view class="schedule-day" hidden="{{activeIndex != k}}" wx:for-index="k" wx:for="{{tabs}}" wx:key="k_key">
      <block wx:for="{{scheduleList[k]}}" wx:for-item="i" wx:key="index">
        <view class="schedule-card">
          <view class="schedule-card__topline">
            <text class="schedule-card__lesson">{{i.scheduleLesson}}</text>
            <text class="schedule-card__week">{{scheduleHelper.formatWeekRange(i.minScheduleWeek, i.maxScheduleWeek, t.weekRange)}}</text>
          </view>
          <view class="schedule-card__name">{{i.scheduleName}}</view>
          <view class="schedule-card__details">
            <view class="schedule-card__detail schedule-card__teacher">{{i.scheduleTeacher}}</view>
            <view class="schedule-card__detail schedule-card__location">{{i.scheduleLocation}}</view>
          </view>
        </view>
      </block>
    </view>

  </view>

</view>
