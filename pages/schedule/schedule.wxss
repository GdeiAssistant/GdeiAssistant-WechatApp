@import "../../common/lib/weui.wxss";

page,
.page,
.page__bd {
  min-height: 100%;
  background-color: var(--color-bg-primary);
}

.schedule-page {
  min-height: 100vh;
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.schedule-navbar {
  position: static;
  background-color: var(--color-surface);
  border-bottom: 1rpx solid var(--color-border);
}

.schedule-navbar .weui-navbar__title {
  white-space: normal;
  line-height: 1.3;
}

.schedule-toolbar {
  padding: 24rpx 24rpx 8rpx;
}

.schedule-week-button {
  width: 100%;
  min-height: 76rpx;
  margin: 0;
  color: var(--color-link);
  background: var(--color-surface);
  border-color: var(--color-border);
  font-size: 30rpx;
  line-height: 1.35;
}

.schedule-panel {
  padding: 8rpx 24rpx 24rpx;
}

.schedule-card {
  margin-top: 20rpx;
  padding: 24rpx;
  color: var(--color-text-primary);
  background-color: var(--color-surface);
  border: 1rpx solid var(--color-border);
  border-radius: 16rpx;
  box-sizing: border-box;
}

.schedule-card__topline {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.schedule-card__lesson {
  min-width: 0;
  margin-right: 20rpx;
  color: var(--color-link);
  font-size: 26rpx;
  line-height: 1.4;
}

.schedule-card__week {
  flex-shrink: 0;
  max-width: 45%;
  color: var(--color-text-secondary);
  font-size: 24rpx;
  line-height: 1.4;
  text-align: right;
  white-space: normal;
}

.schedule-card__name {
  color: var(--color-text-primary);
  font-size: 32rpx;
  font-weight: 600;
  line-height: 1.45;
}

.schedule-card__details {
  display: flex;
  flex-wrap: wrap;
  margin-top: 16rpx;
}

.schedule-card__detail {
  max-width: 100%;
  margin-top: 8rpx;
  color: var(--color-text-secondary);
  font-size: 28rpx;
  line-height: 1.45;
  word-break: break-all;
}

.schedule-card__teacher {
  margin-right: 24rpx;
}

.schedule-card__location {
  color: var(--color-text-primary);
}
