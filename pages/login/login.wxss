@import "../../common/lib/weui.wxss";

.page-section {
  margin-bottom: 35rpx;
}

.page-body {
  margin-top: 35rpx;
}

form {
  width: 100%;
}

.userinfo {
  margin-top: 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.userinfo-avatar {
  width: 128rpx;
  height: 128rpx;
  margin: 20rpx;
  border-radius: 50%;
}

.userinfo-nickname {
  color: #aaa;
}

.userinfo-source {
  color: #bbb;
  font-size: 26rpx;
}

.mock_hint {
  display: block;
  margin: 20rpx 40rpx 0;
  color: #888;
  text-align: center;
  font-size: 26rpx;
}

.settings_link {
  display: block;
  margin-top: 20rpx;
  color: #576b95;
  text-align: center;
  font-size: 28rpx;
}

.version_info {
  margin-top: 35rpx;
  margin-bottom: 35rpx;
  text-align: center;
  color: #aaa;
}
