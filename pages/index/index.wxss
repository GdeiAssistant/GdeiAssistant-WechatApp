@import "../../common/lib/weui.wxss";

.copyright_info {
  margin-top: 35rpx;
  margin-bottom: 35rpx;
  text-align: center;
  color: var(--color-text-tertiary);
}

.userinfo_card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin: 20rpx 24rpx 0;
  padding: 28rpx 30rpx;
  background: linear-gradient(180deg, var(--color-surface) 0%, var(--color-bg-secondary) 100%);
  border-radius: 26rpx;
  box-shadow: 0 14rpx 34rpx rgba(0, 0, 0, 0.05);
}

.userinfo {
  display: flex;
  align-items: center;
  min-width: 0;
  flex: 1;
}

.page-body {
  margin-top: 25rpx;
}

.userinfo-avatar {
  width: 128rpx;
  height: 128rpx;
  margin: 20rpx;
  border-radius: 50%;
}

.userinfo_meta {
  display: flex;
  flex-direction: column;
  min-width: 0;
}

.userinfo-nickname {
  color: var(--color-text-primary);
  font-size: 34rpx;
  font-weight: 600;
}

.userinfo-source {
  margin-top: 8rpx;
  color: var(--color-text-tertiary);
  font-size: 24rpx;
}

.userinfo-entry {
  margin-top: 14rpx;
  color: var(--color-text-secondary);
  font-size: 24rpx;
  text-decoration: underline;
}

.userinfo_notice {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 84rpx;
  height: 84rpx;
  margin-left: 24rpx;
  border-radius: 24rpx;
  background: var(--color-bg-secondary);
  flex-shrink: 0;
}

.userinfo_notice_icon {
  width: 42rpx;
  height: 42rpx;
}

.userinfo_notice_badge {
  position: absolute;
  top: -10rpx;
  right: -12rpx;
  min-width: 36rpx;
  padding: 4rpx 10rpx;
  border-radius: 999rpx;
  background: var(--color-danger);
  color: var(--color-surface);
  font-size: 22rpx;
  text-align: center;
  line-height: 1.2;
  box-shadow: 0 8rpx 18rpx rgba(233, 71, 71, 0.22);
}

.section_title {
  padding: 0 30rpx;
  margin-bottom: 10rpx;
  color: var(--color-text-tertiary);
  font-size: 28rpx;
}

.weui-grids {
  margin-bottom: 20rpx;
}
