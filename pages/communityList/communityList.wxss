@import "../../common/lib/weui.wxss";

.community-page {
  padding-bottom: 130rpx;
  background: var(--color-bg-primary);
  min-height: 100vh;
}

.hero_card {
  margin: 20rpx 24rpx 0;
  padding: 30rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  border-radius: 28rpx;
  box-shadow: 0 16rpx 38rpx rgba(0, 0, 0, 0.05);
}

.hero_content {
  flex: 1;
  min-width: 0;
}

.hero_title {
  color: var(--color-text-primary);
  font-size: 38rpx;
  font-weight: 700;
}

.hero_summary {
  margin-top: 12rpx;
  color: var(--color-text-secondary);
  font-size: 28rpx;
  line-height: 1.7;
}

.hero_icon {
  width: 112rpx;
  height: 112rpx;
  opacity: 0.88;
  flex-shrink: 0;
}

.stats_panel {
  margin: 20rpx 24rpx 0;
  padding: 24rpx;
  display: flex;
  justify-content: space-between;
  background: var(--color-surface);
  border-radius: 20rpx;
  box-shadow: 0 10rpx 24rpx rgba(0, 0, 0, 0.04);
}

.stat_item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.stat_value {
  font-size: 36rpx;
  font-weight: 600;
  color: var(--color-text-primary);
}

.stat_label {
  font-size: 28rpx;
  color: var(--color-text-secondary);
}

.search_bar {
  margin: 20rpx 24rpx 0;
  display: flex;
  gap: 12rpx;
  align-items: center;
  padding: 14rpx;
  background: var(--color-surface);
  border-radius: 24rpx;
  box-shadow: 0 10rpx 24rpx rgba(0, 0, 0, 0.04);
}

.search_input {
  flex: 1;
  height: 76rpx;
  padding: 0 24rpx;
  background: var(--color-bg-secondary);
  border-radius: 999rpx;
  font-size: 28rpx;
}

.search_button {
  margin: 0;
  border-radius: 999rpx;
}

.search_button_secondary {
  background: var(--color-bg-secondary);
  color: var(--color-text-secondary);
}

.tab_scroll {
  white-space: nowrap;
  margin-top: 20rpx;
}

.tab_row {
  display: inline-flex;
  padding: 0 24rpx;
}

.tab_item {
  margin-right: 16rpx;
  padding: 16rpx 28rpx;
  border-radius: 999rpx;
  background: var(--color-surface);
  color: var(--color-text-secondary);
  font-size: 28rpx;
  box-shadow: 0 8rpx 20rpx rgba(0, 0, 0, 0.03);
}

.tab_item_active {
  background: var(--color-text-primary);
  color: var(--color-surface);
}

.list_section {
  padding: 20rpx 24rpx 0;
}

.market_card,
.post_card,
.delivery_card,
.photo_card {
  margin-bottom: 20rpx;
  background: var(--color-surface);
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 14rpx 34rpx rgba(0, 0, 0, 0.045);
}

.market_card {
  display: flex;
}

.market_cover {
  width: 220rpx;
  height: 220rpx;
  flex-shrink: 0;
  background: var(--color-bg-secondary);
}

.market_content {
  flex: 1;
  padding: 24rpx;
}

.lost_grid,
.dating_grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
}

.lost_card,
.dating_card {
  width: 48.2%;
  margin-bottom: 20rpx;
  background: var(--color-surface);
  border-radius: 22rpx;
  overflow: hidden;
  box-shadow: 0 14rpx 34rpx rgba(0, 0, 0, 0.045);
}

.lost_cover,
.dating_cover {
  width: 100%;
  height: 220rpx;
  background: var(--color-bg-secondary);
}

.lost_badges {
  padding: 20rpx 20rpx 0;
  display: flex;
  gap: 8rpx;
  align-items: center;
}

.photo_cover,
.topic_cover {
  width: 100%;
  height: 320rpx;
  background: var(--color-bg-secondary);
}

.delivery_card {
  padding: 26rpx;
}

.delivery_header,
.card_footer,
.card_meta_row,
.post_footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}

.card_title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  line-height: 1.5;
}

.card_summary {
  margin-top: 14rpx;
  color: var(--color-text-secondary);
  font-size: 28rpx;
  line-height: 1.7;
  word-break: break-word;
}

.card_badge,
.card_sub_badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  background: var(--color-bg-tertiary);
  color: var(--color-primary);
  font-size: 22rpx;
}

.card_sub_badge {
  background: var(--color-bg-secondary);
  color: var(--color-text-secondary);
}

.delivery_badge {
  background: #fff3e6;
  color: #f78b28;
}

.card_meta {
  flex: 1;
  color: var(--color-text-secondary);
  font-size: 28rpx;
  line-height: 1.5;
}

.price_text {
  color: var(--color-danger);
  font-size: 32rpx;
  font-weight: 600;
}

.time_text,
.metric_text {
  color: var(--color-text-tertiary);
  font-size: 22rpx;
}

.secret_card {
  padding: 26rpx;
  border-left: 8rpx solid var(--color-text-primary);
}

.dating_card .card_title,
.dating_card .card_meta,
.dating_card .card_summary,
.dating_card .time_text {
  padding: 0 20rpx;
}

.dating_card .card_title {
  margin-top: 18rpx;
}

.dating_card .card_summary {
  min-height: 80rpx;
}

.dating_card .time_text {
  display: block;
  padding-bottom: 20rpx;
}

.photo_card .card_title,
.photo_card .card_summary,
.photo_card .post_footer,
.post_card .card_title,
.post_card .card_summary,
.post_card .post_footer,
.lost_card .card_title,
.lost_card .card_summary,
.lost_card .card_meta,
.lost_card .time_text {
  padding-left: 20rpx;
  padding-right: 20rpx;
}

.photo_card .card_title,
.post_card .card_title,
.lost_card .card_title {
  margin-top: 20rpx;
}

.photo_card .post_footer,
.post_card .post_footer {
  padding-top: 18rpx;
  padding-bottom: 20rpx;
}

.lost_card .time_text {
  display: block;
  padding-top: 12rpx;
  padding-bottom: 20rpx;
}

.bottom_bar {
  position: fixed;
  left: 24rpx;
  right: 24rpx;
  bottom: 20rpx;
  display: flex;
  gap: 16rpx;
  z-index: 20;
}

.bottom_button {
  flex: 1;
  margin: 0;
  border-radius: 999rpx;
}

.bottom_button_secondary {
  background: var(--color-surface);
  color: var(--color-text-primary);
}

.empty_panel {
  margin: 24rpx;
  padding: 52rpx 32rpx;
  background: var(--color-surface);
  border-radius: 24rpx;
  text-align: center;
  box-shadow: 0 12rpx 30rpx rgba(0, 0, 0, 0.04);
}

.empty_title {
  color: var(--color-text-primary);
  font-size: 30rpx;
  font-weight: 600;
}

.empty_summary {
  margin-top: 14rpx;
  color: var(--color-text-tertiary);
  font-size: 24rpx;
  line-height: 1.7;
}
