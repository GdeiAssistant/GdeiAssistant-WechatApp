@import "../../common/lib/weui.wxss";

.section_title {
  margin-top: 20rpx;
  padding: 0 30rpx;
  color: var(--color-text-tertiary);
  font-size: 28rpx;
}

.mock_hint {
  display: block;
  margin: 20rpx 30rpx 0;
  color: var(--color-text-secondary);
  text-align: center;
  font-size: 26rpx;
}

.status_hint {
  margin: 18rpx 30rpx 0;
  color: var(--color-text-secondary);
  font-size: 26rpx;
  line-height: 1.6;
}

.credential_summary {
  display: flex;
  gap: 16rpx;
  margin: 0 30rpx 18rpx;
}

.credential_summary_item {
  flex: 1;
  min-width: 0;
  padding: 18rpx 16rpx;
  border-radius: 12rpx;
  background: var(--color-background);
  border: 1rpx solid var(--color-divider);
}

.credential_summary_item.is_active {
  background: rgba(26, 173, 25, 0.08);
  border-color: rgba(26, 173, 25, 0.18);
}

.credential_summary_label,
.credential_summary_value {
  display: block;
}

.credential_summary_label {
  color: var(--color-text-tertiary);
  font-size: 22rpx;
  line-height: 1.3;
}

.credential_summary_value {
  margin-top: 8rpx;
  color: var(--color-text-secondary);
  font-size: 25rpx;
  font-weight: 600;
  line-height: 1.35;
  word-break: break-all;
}

.credential_summary_item.is_active .credential_summary_value {
  color: var(--color-primary);
}

.credential_cell_note {
  margin-top: 6rpx;
  color: var(--color-text-tertiary);
  font-size: 24rpx;
  line-height: 1.45;
}

.danger_title {
  margin: 24rpx 30rpx 0;
  color: var(--color-text-tertiary);
  font-size: 24rpx;
  font-weight: 600;
}

.action_group {
  display: flex;
  gap: 20rpx;
  padding: 16rpx 30rpx 0;
}

.action_group button {
  flex: 1;
}
