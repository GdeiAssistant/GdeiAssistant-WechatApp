@import "../../common/lib/weui.wxss";

.center_page {
  min-height: 100vh;
  background: var(--color-bg-primary);
  padding-bottom: 120rpx;
}

.hero_card {
  margin: 20rpx 24rpx 0;
  padding: 30rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  border-radius: 28rpx;
  box-shadow: 0 16rpx 38rpx rgba(0, 0, 0, 0.05);
}

.hero_content {
  flex: 1;
  min-width: 0;
}

.hero_title {
  color: var(--color-text-primary);
  font-size: 38rpx;
  font-weight: 700;
}

.hero_summary {
  margin-top: 12rpx;
  color: #777;
  font-size: 24rpx;
  line-height: 1.7;
}

.hero_icon {
  width: 112rpx;
  height: 112rpx;
  opacity: 0.88;
}

.summary_card {
  margin: 20rpx 24rpx 0;
  padding: 26rpx;
  display: flex;
  align-items: center;
  gap: 20rpx;
  background: var(--color-surface);
  border-radius: 24rpx;
  box-shadow: 0 14rpx 34rpx rgba(0, 0, 0, 0.045);
}

.summary_avatar {
  width: 104rpx;
  height: 104rpx;
  border-radius: 50%;
  background: #eef2f3;
  flex-shrink: 0;
}

.summary_content {
  flex: 1;
}

.summary_name {
  color: var(--color-text-primary);
  font-size: 30rpx;
  font-weight: 600;
}

.summary_intro {
  margin-top: 12rpx;
  color: var(--color-text-secondary);
  font-size: 24rpx;
  line-height: 1.7;
}

.tab_scroll {
  margin-top: 20rpx;
}

.tab_row {
  display: inline-flex;
  padding: 0 24rpx;
}

.tab_item {
  margin-right: 16rpx;
  padding: 18rpx 28rpx;
  border-radius: 999rpx;
  background: var(--color-surface);
  color: var(--color-text-secondary);
  font-size: 26rpx;
  box-shadow: 0 8rpx 20rpx rgba(0, 0, 0, 0.03);
}

.tab_item_active {
  background: #2f2f2f;
  color: var(--color-surface);
}

.loading_box,
.empty_box {
  margin: 24rpx;
  padding: 80rpx 30rpx;
  text-align: center;
  color: var(--color-text-tertiary);
  font-size: 26rpx;
  background: var(--color-surface);
  border-radius: 24rpx;
  box-shadow: 0 12rpx 30rpx rgba(0, 0, 0, 0.04);
}

.list_section {
  padding: 20rpx 24rpx 0;
}

.center_card {
  margin-bottom: 20rpx;
  background: var(--color-surface);
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 14rpx 34rpx rgba(0, 0, 0, 0.045);
}

.standard_card {
  display: flex;
}

.center_cover {
  width: 200rpx;
  height: 200rpx;
  background: #eef2f3;
  flex-shrink: 0;
}

.center_content,
.interaction_card {
  flex: 1;
  padding: 24rpx;
}

.card_header,
.action_row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}

.card_title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  line-height: 1.5;
}

.card_summary,
.contact_hint {
  margin-top: 12rpx;
  color: var(--color-text-secondary);
  font-size: 26rpx;
  line-height: 1.7;
}

.card_time {
  margin-top: 12rpx;
  color: var(--color-text-tertiary);
  font-size: 22rpx;
}

.price_text {
  color: #ea4335;
  font-size: 30rpx;
  font-weight: 600;
}

.action_row {
  margin-top: 20rpx;
}

.bottom_bar {
  position: fixed;
  left: 24rpx;
  right: 24rpx;
  bottom: 20rpx;
}

.bottom_button {
  border-radius: 999rpx;
}

.empty_title {
  color: var(--color-text-primary);
  font-size: 30rpx;
  font-weight: 600;
}

.empty_summary {
  margin-top: 12rpx;
  color: var(--color-text-tertiary);
  font-size: 24rpx;
  line-height: 1.7;
}
