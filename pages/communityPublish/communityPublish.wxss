@import "../../common/lib/weui.wxss";

.publish_page {
  min-height: 100vh;
  background: var(--color-bg-primary);
  padding: 20rpx 24rpx 40rpx;
  box-sizing: border-box;
}

.hero_card {
  margin-bottom: 20rpx;
  padding: 30rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  border-radius: 28rpx;
  box-shadow: 0 16rpx 38rpx rgba(0, 0, 0, 0.05);
}

.hero_content {
  flex: 1;
  min-width: 0;
}

.hero_title {
  color: var(--color-text-primary);
  font-size: 38rpx;
  font-weight: 700;
}

.hero_summary {
  margin-top: 12rpx;
  color: var(--color-text-secondary);
  font-size: 24rpx;
  line-height: 1.7;
}

.hero_icon {
  width: 112rpx;
  height: 112rpx;
  opacity: 0.88;
}

.publish_card {
  margin-bottom: 20rpx;
  padding: 26rpx;
  background: var(--color-surface);
  border-radius: 24rpx;
  box-shadow: 0 14rpx 34rpx rgba(0, 0, 0, 0.045);
}

.section_title {
  margin-bottom: 18rpx;
  color: var(--color-text-primary);
  font-size: 28rpx;
  font-weight: 600;
}

.page_hint {
  margin-bottom: 18rpx;
  color: var(--color-text-tertiary);
  font-size: 24rpx;
}

.picker_value {
  color: var(--color-text-primary);
  font-size: 28rpx;
}

.voice_panel {
  margin-top: 20rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.voice_hint,
.upload_hint {
  color: var(--color-text-tertiary);
  font-size: 24rpx;
}

.image_list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.image_item,
.image_add {
  position: relative;
  width: 200rpx;
  height: 200rpx;
  border-radius: 22rpx;
  overflow: hidden;
  background: var(--color-bg-secondary);
}

.image_preview {
  width: 100%;
  height: 100%;
}

.image_remove {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: rgba(0, 0, 0, 0.5);
  color: var(--color-surface);
  text-align: center;
  line-height: 40rpx;
  font-size: 24rpx;
}

.image_add {
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--color-primary);
  font-size: 72rpx;
}

.submit_area {
  margin-top: 30rpx;
}
