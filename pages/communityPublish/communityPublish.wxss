@import "../../common/lib/weui.wxss";

.publish_page {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 20rpx 24rpx 40rpx;
  box-sizing: border-box;
}

.publish_card {
  margin-bottom: 20rpx;
  padding: 24rpx;
  background: #fff;
  border-radius: 20rpx;
  box-shadow: 0 10rpx 24rpx rgba(0, 0, 0, 0.04);
}

.section_title {
  margin-bottom: 18rpx;
  color: #222;
  font-size: 28rpx;
  font-weight: 600;
}

.page_hint {
  margin-bottom: 18rpx;
  color: #999;
  font-size: 24rpx;
}

.picker_value {
  color: #333;
  font-size: 28rpx;
}

.voice_panel {
  margin-top: 20rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.voice_hint,
.upload_hint {
  color: #999;
  font-size: 24rpx;
}

.image_list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.image_item,
.image_add {
  position: relative;
  width: 200rpx;
  height: 200rpx;
  border-radius: 18rpx;
  overflow: hidden;
  background: #f2f4f5;
}

.image_preview {
  width: 100%;
  height: 100%;
}

.image_remove {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: rgba(0, 0, 0, 0.5);
  color: #fff;
  text-align: center;
  line-height: 40rpx;
  font-size: 24rpx;
}

.image_add {
  display: flex;
  align-items: center;
  justify-content: center;
  color: #3cb395;
  font-size: 72rpx;
}

.submit_area {
  margin-top: 30rpx;
}
