@import "../../common/lib/weui.wxss";

.inbox_page {
  padding-bottom: 28rpx;
  background: var(--color-bg-primary);
}

.inbox_tabs {
  position: sticky;
  top: 0;
  z-index: 20;
  background-color: var(--color-surface);
}

.section_card {
  margin: 24rpx 24rpx 0;
  background: var(--color-surface);
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 12rpx 32rpx rgba(0, 0, 0, 0.04);
}

.item_title {
  padding-right: 20rpx;
  color: var(--color-text-primary);
  word-break: break-word;
}

.item_summary {
  margin-top: 8rpx;
  color: var(--color-text-tertiary);
  font-size: 24rpx;
  line-height: 1.6;
}

.item_date {
  font-size: 24rpx;
}

.interaction_meta {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 28rpx 4rpx;
}

.meta_badge {
  color: var(--color-text-secondary);
  font-size: 24rpx;
}

.meta_action {
  color: var(--color-text-secondary);
  font-size: 24rpx;
}

.interaction_list {
  padding: 12rpx 24rpx 20rpx;
}

.interaction_card {
  margin-top: 16rpx;
  padding: 24rpx;
  border-radius: 18rpx;
  background: var(--color-bg-primary);
}

.interaction_card:first-child {
  margin-top: 0;
}

.interaction_card_active {
  background: var(--color-bg-secondary);
}

.interaction_header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.interaction_title {
  flex: 1;
  min-width: 0;
  color: var(--color-text-primary);
  font-size: 30rpx;
  font-weight: 600;
}

.interaction_read {
  flex-shrink: 0;
  padding: 4rpx 12rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
}

.interaction_read_done {
  background: var(--color-divider);
  color: var(--color-text-tertiary);
}

.interaction_read_pending {
  background: var(--color-border);
  color: var(--color-text-secondary);
}

.interaction_tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 16rpx;
}

.interaction_tag {
  padding: 4rpx 12rpx;
  border-radius: 999rpx;
  background: var(--color-bg-tertiary);
  color: var(--color-text-secondary);
  font-size: 22rpx;
}

.interaction_tag_secondary {
  background: var(--color-bg-secondary);
}

.interaction_content {
  margin-top: 18rpx;
  color: var(--color-text-secondary);
  font-size: 26rpx;
  line-height: 1.7;
}

.interaction_time {
  margin-top: 18rpx;
  color: var(--color-text-tertiary);
  font-size: 22rpx;
}
